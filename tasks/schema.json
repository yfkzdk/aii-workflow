{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["task_id", "step", "status", "payload"],
  "properties": {
    "task_id": {"type": "string"},
    "step": {"enum": ["planning", "prompt_optimizing", "executing", "verifying", "archiving"]},
    "status": {"enum": ["ready", "success", "failed"]},
    "payload": {"type": "object", "additionalProperties": true}
  }
}
