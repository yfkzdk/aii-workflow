{
  "name": "aii-workflow",
  "version": "1.0.0",
  "description": "AII Workflow VS Code Extension",
  "main": "dist/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
