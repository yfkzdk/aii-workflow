{
  "pipeline": [
    "input_collecting",
    "requirement_optimizing",
    "confirmation",
    "planning",
    "prompt_optimizing",
    "executing",
    "verifying",
    "archiving"
  ],
  "agents": {
    "input_collector": {
      "role": "用户输入收集",
      "input": "用户交互",
      "output": "user_input (state.json)",
      "skills": []
    },
    "requirement_optimizer": {
      "role": "需求优化与方案生成",
      "input": "user_input (state.json)",
      "output": "artifacts/optimized_requirement.json",
      "skills": []
    },
    "planner": {
      "role": "需求拆解",
      "input": "artifacts/optimized_requirement.json",
      "output": "artifacts/requirements.md",
      "skills": []
    },
    "prompt_optimizer": {
      "role": "通用提示词优化 (DEBATE)",
      "input": "artifacts/requirements.md",
      "output": "artifacts/optimal_prompt.md",
      "skills": ["simplify"]
    },
    "prompt_optimizer_v2": {
      "role": "激进型提示词优化 (DEBATE)",
      "input": "artifacts/requirements.md",
      "output": "artifacts/optimal_prompt_v2.md",
      "skills": ["simplify"]
    },
    "prompt_optimizer_v3": {
      "role": "安全保守型提示词优化 (DEBATE)",
      "input": "artifacts/requirements.md",
      "output": "artifacts/optimal_prompt_v3.md",
      "skills": ["simplify"]
    },
    "reviewer": {
      "role": "评审专家 (DEBATE reviewer)",
      "input": "多份提示词候选",
      "output": "artifacts/debate_verdict.json",
      "skills": ["review"]
    },
    "coder": {
      "role": "代码实现",
      "input": "artifacts/optimal_prompt.md",
      "output": "artifacts/code/",
      "skills": ["simplify", "security-review"]
    },
    "coder_frontend": {
      "role": "前端开发 (PARALLEL)",
      "input": "artifacts/optimal_prompt.md",
      "output": "artifacts/code/frontend/",
      "skills": ["simplify", "frontend-design"]
    },
    "coder_backend": {
      "role": "后端开发 (PARALLEL)",
      "input": "artifacts/optimal_prompt.md",
      "output": "artifacts/code/backend/",
      "skills": ["security-review", "claude-api"]
    },
    "coder_tests": {
      "role": "测试工程师 (PARALLEL)",
      "input": "artifacts/optimal_prompt.md",
      "output": "artifacts/code/test_main.py",
      "skills": ["review", "pytest"]
    },
    "verifier": {
      "role": "测试验证",
      "input": "artifacts/code/",
      "output": "artifacts/test_report.json",
      "skills": ["review", "security-review"]
    },
    "archivist": {
      "role": "归档索引",
      "input": "artifacts/*",
      "output": "AI_WORKFLOW_LOG.md",
      "skills": []
    }
  },
  "multi_agent_stages": {
    "prompt_optimizing": {
      "strategy": "debate",
      "agents": ["prompt_optimizer", "prompt_optimizer_v2", "prompt_optimizer_v3"],
      "reviewer": "reviewer",
      "merge_strategy": "pick_best"
    },
    "executing": {
      "strategy": "parallel",
      "agents": ["coder", "coder_tests"],
      "merge_strategy": "concat",
      "note": "Runs coder and test engineer in parallel based on the optimal prompt"
    }
  },
  "confirmation_gate": {
    "description": "用户确认门：需求优化完成后暂停，等待用户选择方案、修改澄清项、指定skill",
    "actions": {
      "confirm": "确认方案，进入planning",
      "revise": "修改需求，回到requirement_optimizing",
      "reject": "取消任务"
    }
  }
}