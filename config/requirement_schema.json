{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "requirement_schema.json",
  "title": "Optimized Requirement Schema",
  "description": "JSON Schema for requirement optimization output",
  "type": "object",
  "required": [
    "original_requirement",
    "clarifications",
    "proposals",
    "agent_assignments",
    "task_dag_preview"
  ],
  "properties": {
    "original_requirement": {
      "type": "string",
      "description": "The complete original user requirement text",
      "minLength": 1
    },
    "clarifications": {
      "type": "array",
      "description": "List of clarification items for user confirmation",
      "items": {
        "type": "object",
        "required": ["point", "original", "inferred", "confidence", "needs_user_confirm"],
        "properties": {
          "point": {
            "type": "string",
            "description": "Clarification topic name"
          },
          "original": {
            "type": "string",
            "description": "Original user statement or absence"
          },
          "inferred": {
            "type": "string",
            "description": "Inferred interpretation"
          },
          "reasoning": {
            "type": "string",
            "description": "Reasoning chain for this inference"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Confidence level (0-1), values < 0.8 require user confirmation"
          },
          "needs_user_confirm": {
            "type": "boolean",
            "description": "Whether this item requires user confirmation"
          },
          "alternatives": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Alternative interpretations"
          }
        }
      }
    },
    "proposals": {
      "type": "array",
      "description": "Implementation proposals (2-3 items: A=Minimal, B=Standard, C=Full if complexity >= 1.5)",
      "minItems": 2,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "scope", "estimated_tasks", "skills_recommended", "pros", "cons"],
        "properties": {
          "id": {
            "type": "string",
            "enum": ["A", "B", "C"],
            "description": "Proposal identifier"
          },
          "name": {
            "type": "string",
            "description": "Display name"
          },
          "description": {
            "type": "string",
            "description": "Detailed description"
          },
          "scope": {
            "type": "string",
            "enum": ["minimal", "standard", "full"],
            "description": "Scope level"
          },
          "estimated_tasks": {
            "type": "integer",
            "minimum": 1,
            "description": "Estimated number of tasks"
          },
          "skills_recommended": {
            "type": "array",
            "description": "Recommended skills with match details",
            "items": {
              "type": "object",
              "required": ["agent_id", "skills"],
              "properties": {
                "agent_id": {
                  "type": "string",
                  "description": "Target agent ID"
                },
                "skills": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "source"],
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "Skill ID from config/skills.json"
                      },
                      "source": {
                        "type": "string",
                        "enum": ["auto_match", "user_specified", "default"],
                        "description": "How this skill was selected"
                      },
                      "match_score": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1,
                        "description": "Auto-match confidence score"
                      },
                      "reason": {
                        "type": "string",
                        "description": "Match explanation"
                      }
                    }
                  }
                }
              }
            }
          },
          "pros": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "description": "Advantages of this proposal"
          },
          "cons": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "description": "Disadvantages of this proposal"
          },
          "reasoning": {
            "type": "string",
            "description": "Why this proposal is recommended or not"
          }
        }
      }
    },
    "agent_assignments": {
      "type": "array",
      "description": "Agent role assignments with parallel relationships",
      "items": {
        "type": "object",
        "required": ["agent_id", "role", "responsibility", "input_from", "skills", "parallel_with"],
        "properties": {
          "agent_id": {
            "type": "string",
            "description": "Agent identifier (planner, coder, coder_frontend, coder_backend, verifier, archivist)"
          },
          "role": {
            "type": "string",
            "description": "Human-readable role name"
          },
          "responsibility": {
            "type": "string",
            "description": "What this agent is responsible for"
          },
          "input_from": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ],
            "description": "Source stage or agent for input"
          },
          "skills": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "source"],
              "properties": {
                "id": { "type": "string" },
                "source": { "type": "string" },
                "match_score": { "type": "number" }
              }
            },
            "description": "Skills assigned to this agent"
          },
          "parallel_with": {
            "type": ["string", "null"],
            "description": "Agent ID to run in parallel with, or null for sequential"
          }
        }
      }
    },
    "task_dag_preview": {
      "type": "object",
      "description": "Preview of task dependency graph",
      "required": ["nodes", "edges"],
      "properties": {
        "nodes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of task node identifiers"
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 2,
            "maxItems": 2
          },
          "description": "List of [from, to] edges"
        },
        "parallel_groups": {
          "type": "array",
          "description": "Groups of tasks that can run in parallel",
          "items": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "features_detected": {
      "type": "object",
      "description": "Detected requirement features",
      "properties": {
        "has_frontend": {
          "type": "object",
          "properties": {
            "detected": { "type": "boolean" },
            "evidence": { "type": ["string", "null"] }
          }
        },
        "has_backend": {
          "type": "object",
          "properties": {
            "detected": { "type": "boolean" },
            "evidence": { "type": ["string", "null"] }
          }
        },
        "has_ai": {
          "type": "object",
          "properties": {
            "detected": { "type": "boolean" },
            "evidence": { "type": ["string", "null"] }
          }
        },
        "has_network": {
          "type": "object",
          "properties": {
            "detected": { "type": "boolean" },
            "evidence": { "type": ["string", "null"] }
          }
        },
        "has_security": {
          "type": "object",
          "properties": {
            "detected": { "type": "boolean" },
            "evidence": { "type": ["string", "null"] }
          }
        },
        "has_game": {
          "type": "object",
          "properties": {
            "detected": { "type": "boolean" },
            "evidence": { "type": ["string", "null"] }
          }
        },
        "complexity_score": {
          "type": "number",
          "minimum": 0,
          "description": "Calculated complexity score"
        },
        "domain_tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Extracted domain tags"
        }
      }
    },
    "reasoning_trace": {
      "type": "object",
      "description": "Reasoning process summary",
      "properties": {
        "feature_analysis": {
          "type": "string",
          "description": "How features were derived from requirement"
        },
        "proposal_decision": {
          "type": "string",
          "description": "Why proposals were chosen"
        },
        "skill_matching_logic": {
          "type": "string",
          "description": "How skills were matched"
        },
        "agent_assignment_rationale": {
          "type": "string",
          "description": "Why agents were assigned this way"
        }
      }
    },
    "optimized_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp of optimization"
    }
  }
}